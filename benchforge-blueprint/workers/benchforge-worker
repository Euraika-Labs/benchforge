#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

python_meets_minimum() {
  local python_bin="$1"
  "$python_bin" - <<'PY' >/dev/null 2>&1
import sys
raise SystemExit(0 if sys.version_info >= (3, 10) else 1)
PY
}

resolve_python_candidate() {
  local candidate="$1"
  if command -v "$candidate" >/dev/null 2>&1; then
    command -v "$candidate"
    return 0
  fi
  if [[ -x "$candidate" ]]; then
    printf "%s\n" "$candidate"
    return 0
  fi
  return 1
}

select_python() {
  local candidates=()
  local candidate python_bin version_line old_versions=()

  if [[ -n "${BENCHFORGE_PYTHON:-}" ]]; then
    candidates=("$BENCHFORGE_PYTHON")
  else
    candidates=("$ROOT/.venv/bin/python" python3 python3.13 python3.12 python3.11 python3.10 python /opt/homebrew/bin/python3 /usr/local/bin/python3)
  fi

  for candidate in "${candidates[@]}"; do
    python_bin="$(resolve_python_candidate "$candidate" || true)"
    [[ -n "$python_bin" ]] || continue

    version_line="$("$python_bin" --version 2>&1 | head -n 1)"
    if python_meets_minimum "$python_bin"; then
      printf "%s\n" "$python_bin"
      return 0
    fi
    old_versions+=("$version_line at $python_bin")
  done

  echo "benchforge-worker requires Python 3.10+ on PATH." >&2
  if [[ "${#old_versions[@]}" -gt 0 ]]; then
    printf "Found older Python interpreter: %s\n" "${old_versions[@]}" >&2
  fi
  echo "Install Python with 'brew install python' or set BENCHFORGE_PYTHON=/path/to/python3.10+." >&2
  return 127
}

PYTHON_BIN="$(select_python)"

PYTHONPATH="$ROOT${PYTHONPATH:+:$PYTHONPATH}" exec "$PYTHON_BIN" -m benchforge_worker.cli "$@"
